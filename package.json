{
  "name": "hub",
  "version": "0.0.0",
  "private": true,
  "homepage": "https://github.com/donniean/hub#readme",
  "bugs": {
    "url": "https://github.com/donniean/hub/issues"
  },
  "license": "MIT",
  "author": "Donnie An",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/donniean/hub.git"
  },
  "type": "module",
  "scripts": {
    "format:oxfmt": "oxfmt",
    "format:oxfmt:check": "oxfmt --check",
    "lint": "concurrently --group --timings \"pnpm:format:*:check\" \"pnpm:lint:*(!:fix)\" \"pnpm:typecheck\"",
    "lint:autocorrect": "autocorrect --lint",
    "lint:autocorrect:fix": "autocorrect --fix",
    "lint:fix": "concurrently --max-processes=1 --group --timings \"pnpm:lint:*:fix\" \"pnpm:format:*(!:check)\"",
    "lint:html": "html-validate \"**/*.html\"",
    "lint:knip": "knip",
    "lint:knip:fix": "knip --fix",
    "lint:markdown": "markdownlint --dot \"**/*.md\"",
    "lint:markdown:fix": "pnpm run lint:markdown --fix",
    "lint:oxlint": "oxlint",
    "lint:oxlint:fix": "oxlint --fix",
    "lint:spellcheck": "cspell lint --no-progress --no-must-find-files --dot --gitignore .",
    "lint:styles": "stylelint \"**/*.css\"",
    "lint:styles:fix": "pnpm run lint:styles --fix",
    "ncu": "ncu --deep --format cooldown",
    "ncu:upgrade": "pnpm run ncu --upgrade",
    "prepare": "husky",
    "serve": "serve apps/playground/",
    "test": "pnpm run test:unit",
    "test:unit": "vitest run --pass-with-no-tests",
    "test:unit:coverage": "vitest run --coverage",
    "test:unit:ui": "vitest --ui",
    "test:unit:watch": "vitest watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@commitlint/types": "21.0.1",
    "@types/node": "24.13.2",
    "@vitest/coverage-v8": "4.1.9",
    "@vitest/ui": "4.1.9",
    "autocorrect-node": "2.14.0",
    "concurrently": "10.0.3",
    "cspell": "10.0.1",
    "html-validate": "11.5.3",
    "husky": "9.1.7",
    "knip": "6.17.1",
    "lint-staged": "17.0.8",
    "markdownlint-cli": "0.49.0",
    "npm-check-updates": "22.2.7",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "oxlint-tsgolint": "0.23.0",
    "serve": "14.2.6",
    "stylelint": "17.13.0",
    "stylelint-config-recess-order": "7.7.0",
    "stylelint-config-standard": "40.0.0",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "packageManager": "pnpm@11.8.0"
}
